NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
AI_PROVIDER=openrouter
AI_TEXT_MODEL_FAST=deepseek/deepseek-v4-flash
AI_TEXT_MODEL_PRO=deepseek/deepseek-v4-pro
AI_VISION_MODEL_PRIMARY=google/gemini-3.1-pro-preview
AI_VISION_MODEL_FALLBACK=qwen/qwen3-vl-235b-a22b-instruct
AI_EXPERT_REVIEW_MODEL=openai/gpt-5.6-terra
OPENROUTER_API_KEY=

# 灰度开关：确认新路由测试通过后再在 Production 设为 true
AI_UNIFIED_POLICY_PARSING=false

# OpenClaw HTTPS Gateway（切换 AI_PROVIDER=openclaw 后启用）
OPENCLAW_BASE_URL=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ACCESS_TOKEN=

# 旧版 AI 路由兼容变量；核心保单解析迁移完成后删除。
AI_FALLBACK_PROVIDER=openrouter
OPENCLAW_POLICY_AGENT=openclaw/policy-analysis
OPENCLAW_CUSTOMER_AGENT=openclaw/customer-analysis
OPENCLAW_REPORT_AGENT=openclaw/report-generation
OPENAI_API_KEY=sk-your-openai-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-flash
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DISABLE_USAGE_LIMITS=false
